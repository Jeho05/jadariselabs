# ============================================
# JadaRiseLabs — Variables d'Environnement
# ============================================
# Copier ce fichier en .env.local et remplir les valeurs

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- IA : Groq (Chat / Code) ---
GROQ_API_KEY=your-groq-api-key

# --- IA : Google Studio (Fallback Chat) ---
GEMINI_API_KEY=your-gemini-api-key

# --- IA : Hugging Face (Images/Audio Fallback) ---
HUGGINGFACE_API_KEY=your-huggingface-api-key

# --- IA : Replicate (Vidéo Fallback) ---
REPLICATE_API_TOKEN=your-replicate-api-token

# --- IA : Fal.ai (Vidéo/Image Premium) ---
FAL_KEY=your-fal-api-key

# --- IA : Fish Audio (Voice/TTS) ---
FISH_AUDIO_API_KEY=your-fish-audio-api-key

# --- Paiement : CinetPay ---
CINETPAY_API_KEY=your-cinetpay-api-key
CINETPAY_SITE_ID=your-cinetpay-site-id
CINETPAY_SECRET_KEY=your-cinetpay-secret-key

# --- Email : SendGrid ---
SENDGRID_API_KEY=your-sendgrid-api-key

# --- Email : Resend ---
RESEND_API_KEY=your-resend-api-key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
