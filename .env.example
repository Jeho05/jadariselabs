# ============================================
# JadaRiseLabs — Variables d'Environnement
# ============================================
# Copier ce fichier en .env.local et remplir les valeurs

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- IA : Groq (Chat / Code) ---
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# --- IA : Google Studio (Fallback Chat) ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# --- IA : DeepSeek (Reasoning) ---
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://your-openai-compatible-base
DEEPSEEK_MODEL=your-deepseek-model

# --- IA : Zhipu AI (Agentic Coding) ---
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4
ZHIPU_CODE_API_BASE=https://open.bigmodel.cn/api/coding/paas/v4
ZHIPU_MODEL=glm-5

# --- IA : Hugging Face (Images/Audio Fallback) ---
HUGGINGFACE_API_KEY=your-huggingface-api-key

# --- IA : remove.bg (Background Removal) ---
REMOVEBG_API_KEY=your-removebg-api-key

# --- IA : Replicate (Vidéo Fallback) ---
REPLICATE_API_TOKEN=your-replicate-api-token

# --- IA : Fal.ai (Vidéo/Image Premium) ---
FAL_KEY=your-fal-api-key

# --- IA : MiniMax (Hailuo Video) ---
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_API_BASE=https://api.minimax.io/v1
MINIMAX_MODEL=video-01

# --- IA : SiliconFlow (Chat/Image gratuit, 137 modèles) ---
SILICONFLOW_API_KEY=your-siliconflow-api-key

# --- IA : iFlytek Spark (Chat illimité) ---
IFLYTEK_API_KEY=your-iflytek-api-key
IFLYTEK_API_SECRET=your-iflytek-api-secret
IFLYTEK_APP_ID=your-iflytek-app-id

# --- IA : Alibaba Cloud DashScope (Qwen3-TTS / Image) ---
DASHSCOPE_API_KEY=your-dashscope-api-key

# --- IA : Fish Audio (Voice/TTS Fallback) ---
FISH_AUDIO_API_KEY=your-fish-audio-api-key

# --- Paiement : CinetPay ---
CINETPAY_API_KEY=your-cinetpay-api-key
CINETPAY_SITE_ID=your-cinetpay-site-id
CINETPAY_SECRET_KEY=your-cinetpay-secret-key

# --- Email : SendGrid ---
SENDGRID_API_KEY=your-sendgrid-api-key

# --- Email : Resend ---
RESEND_API_KEY=your-resend-api-key

# --- Recherche Web ---
TAVILY_API_KEY=your-tavily-api-key
EXA_API_KEY=your-exa-api-key
BRAVE_SEARCH_API_KEY=your-brave-search-api-key
FIRECRAWL_API_KEY=your-firecrawl-api-key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cron (Vercel Cron -> /api/cron/social-autopilot) ---
# Vercel enverra automatiquement: Authorization: Bearer $CRON_SECRET
CRON_SECRET=your-cron-secret
